# pnpm 11 — keep `pnpm install` non-interactive in CI. The release
# workflow has no stdin to answer pnpm's "approve build scripts?"
# prompt for esbuild (transitive via vitest -> @vitest/expect ->
# tinypool -> ...). dangerously-allow-all-builds lets every dep's
# postinstall scripts run; safe here because the action repo has
# no untrusted deps and `dist/index.js` is rebuilt by hand anyway.
dangerously-allow-all-builds=true
auto-install-peers=true
